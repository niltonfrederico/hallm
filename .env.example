# Application
DEBUG=false
APP_PORT=8000

# Database
DATABASE_DRIVER=postgres
DATABASE_LOCAL_HOST=postgres.hallm.local
DATABASE_PROD_HOST=postgres.default.svc.cluster.local
POSTGRES_USER=hallm
POSTGRES_PASSWORD=hallm_password
POSTGRES_DB=hallm
POSTGRES_PORT=5432

# Db schemas
HALLM_DB_SCHEMA=hallm
LIBRARY_DB_SCHEMA=library

# Model API Keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=

# RustFS (S3-compatible object storage)
RUSTFS_ENDPOINT=http://rustfs.default.svc.cluster.local:9000
RUSTFS_ACCESS_KEY=hallm_rustfs
RUSTFS_SECRET_KEY=hallm_rustfs_password
RUSTFS_BUCKET=hallm
RUSTFS_REGION=us-east-1
RUSTFS_PRESIGN_EXPIRES=3600

# Valkey (shared cache)
VALKEY_URL=redis://valkey.default.svc.cluster.local:6379/0
VALKEY_PASSWORD=hallm_valkey_password

# Gotify
GOTIFY_URL=https://gotify.hallm.local
GOTIFY_APP_TOKEN=

# Paperless-ngx
PAPERLESS_URL=https://paperless.hallm.local
PAPERLESS_TOKEN=
PAPERLESS_SECRET_KEY=change-me-paperless-secret
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=hallm_paperless_admin

# Glitchtip
GLITCHTIP_DSN=
GLITCHTIP_SECRET_KEY=change-me-glitchtip-secret

# SigNoz / OpenTelemetry
OTEL_ENDPOINT=http://signoz-otel-collector.signoz.svc.cluster.local:4317
OTEL_SERVICE_NAME=hallm

# MongoDB (Habitica + your_spotify)
MONGO_INITDB_ROOT_USERNAME=hallm
MONGO_INITDB_ROOT_PASSWORD=hallm_mongo_password

# Habitica
HABITICA_BASE_URL=https://habitica.hallm.local
HABITICA_SESSION_SECRET=change-me-habitica-secret

# Spotify (your_spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_PUBLIC_URL=https://spotify.hallm.local

# Heimdall
HEIMDALL_PUID=1000
HEIMDALL_PGID=1000
HEIMDALL_TZ=UTC

# ots.fyi
OTS_SECRET=change-me-ots-secret
OTS_HOST=ots.hallm.local

# OpenClaw
OPENCLAW_AUTH_TOKEN=change-me-openclaw-token

# ActivityWatch
AW_HOST=0.0.0.0
AW_PORT=5600

# Per-service Postgres databases (created by `hallm db bootstrap`)
GLITCHTIP_DB=glitchtip
PAPERLESS_DB=paperless
